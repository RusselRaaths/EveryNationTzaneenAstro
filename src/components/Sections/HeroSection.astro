---
import Button from "../UI/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  backgroundImage?: string;
  backgroundImages?: string[];
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const {
  title = "Welcome to Every Nation Tzaneen",
  subtitle = "A Disciple Making Family",
  backgroundImage = "",
  backgroundImages = [],
  ctaText = "Plan Your Visit",
  ctaLink = `${base}/im-new`,
  secondaryCtaText = "Watch Sermons",
  secondaryCtaLink = `${base}/sermons`,
} = Astro.props;

// default set of images from public/uploads
const defaultImages = [
  `${base}/uploads/home-1.webp`,
  `${base}/uploads/home-2.webp`,
  `${base}/uploads/home-3.webp`,
  `${base}/uploads/home-4.webp`,
  `${base}/uploads/home-5.webp`,
  `${base}/uploads/home-6.webp`,
  `${base}/uploads/home-7.webp`,
  `${base}/uploads/home-8.webp`,
  `${base}/uploads/home-9.webp`,
  `${base}/uploads/home-10.webp`,
  `${base}/uploads/home-11.webp`,
];

const imagesToUse = (() => {
  if (backgroundImage && backgroundImage.length > 0) return [backgroundImage];
  if (Array.isArray(backgroundImages) && backgroundImages.length > 0) return backgroundImages;
  return defaultImages;
})();
---

<section
  id="hero-section"
  class="relative min-h-[70vh] flex items-center bg-cover pt-30"
  data-bg-images={JSON.stringify(imagesToUse)}
  style={`background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('${encodeURI(imagesToUse[0])}'); background-position: center 20%;`}
>
  <div class="container">
    <div class="max-w-3xl text-white">
      <h1 class="text-4xl md:text-6xl font-bold mb-4 text-white">{title}</h1>
      <p class="text-xl md:text-2xl mb-8">{subtitle}</p>

      <div class="flex flex-wrap gap-4">
        <Button href={ctaLink} variant="primary" size="lg">
          {ctaText}
        </Button>

        <Button
          href={secondaryCtaLink}
          variant="outline"
          size="lg"
          class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm"
        >
          {secondaryCtaText}
        </Button>
      </div>
    </div>
  </div>
</section>

<script type="module">
  (function () {
    const section = document.getElementById('hero-section');
    if (!section) return;

    let images = [];
    try {
      images = JSON.parse(section.dataset.bgImages || '[]');
    } catch (e) {
      images = [];
    }
    if (!images || images.length === 0) return;

    let idx = 0;
    const interval = 5000;

    setInterval(() => {
      idx = (idx + 1) % images.length;
      section.style.backgroundImage = `linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('${encodeURI(images[idx])}')`;
    }, interval);
  })();
</script>
