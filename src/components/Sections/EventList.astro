---
import { getCollection } from "astro:content";
import Button from "../UI/Button.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const allEvents = await getCollection("events");
const upcomingEvents = allEvents
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);
---

<section class="py-16 bg-white">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Upcoming Events</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Join us for these special gatherings and community events
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {upcomingEvents.map((event) => (
        <article class="card overflow-hidden">
          {event.data.image && (
            <img
              src={event.data.image}
              alt={event.data.title}
              class="w-full h-48 object-cover"
            />
          )}

          <div class="p-6">
            <p class="text-sm font-semibold text-primary-600 mb-2">
              {new Date(event.data.date).toLocaleDateString("en-ZA", {
                weekday: "short",
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>

            <h3 class="text-xl font-bold mb-3">{event.data.title}</h3>

            {event.data.description && (
              <p class="text-gray-600 mb-4 line-clamp-3">{event.data.description}</p>
            )}

            <Button href={`${base}/events/${event.slug}`} variant="outline">
              Learn More
            </Button>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <Button href={`${base}/events`} variant="outline">
        View All Events
      </Button>
    </div>
  </div>
</section>
