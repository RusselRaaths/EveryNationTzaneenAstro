---
export interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
  backgroundImages?: string[];
  imageFit?: 'cover' | 'contain' | 'stretch';
  imagePosition?: string;
  tile?: number; // number of tiled copies to show (e.g., 4 -> 2x2)
  repeatX?: boolean; // repeat the background image horizontally (repeat-x)
}

const {
  title, 
  subtitle, 
  backgroundImage = "/uploads/page-header-bg.webp",
  backgroundImages = undefined,
  imageFit = 'cover',
  imagePosition = 'center',
  repeatX = false,
} = Astro.props;

// If `tile` is provided, compute a grid (cols x rows) that fits the tile count and
// set background-size so the image repeats to form the grid.
let backgroundSize: string;
let backgroundRepeat = 'no-repeat';
if (repeatX) {
  // Repeat horizontally, keep full height
  backgroundRepeat = 'repeat-x';
  backgroundSize = 'auto 100%';
} else if (typeof Astro.props.tile === 'number' && Astro.props.tile > 1) {
  const tile = Astro.props.tile;
  const cols = Math.ceil(Math.sqrt(tile));
  const rows = Math.ceil(tile / cols);
  backgroundSize = `${100 / cols}% ${100 / rows}%`;
  backgroundRepeat = 'repeat';
} else {
  backgroundSize = imageFit === 'stretch' ? '100% 100%' : imageFit;
}

---

<section class="relative py-20 bg-center overflow-hidden">
  {backgroundImages && Array.isArray(backgroundImages) && backgroundImages.length > 0 ? (
    /* render side-by-side images */
    <div class="absolute inset-0 flex">
      {backgroundImages.map((img) => (
        <div
          class="flex-1 bg-center bg-no-repeat"
          style={`background-image: url('${encodeURI(img)}'); background-size: ${backgroundSize}; background-position: ${imagePosition};`}
        />
      ))}
      {/* gradient overlay */}
      <div class="absolute inset-0" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6));"></div>
    </div>
  ) : (
    /* single background image fallback (original behavior) */
    <div class="absolute inset-0 bg-center" style={`background-size: ${backgroundSize}; background-position: ${imagePosition}; background-repeat: ${backgroundRepeat}; background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('${encodeURI(backgroundImage)}')`} />
  )}
  <div class="container">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">{title}</h1>
      {subtitle && <p class="text-xl md:text-2xl">{subtitle}</p>}
    </div>
  </div>
</section>