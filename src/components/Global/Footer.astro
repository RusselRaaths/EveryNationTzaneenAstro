const currentYear = new Date().getFullYear();

// Render office hours content if available
let OfficeHoursContent = null;
if (officeHours) {
  const { Content } = await officeHours.render();
  OfficeHoursContent = Content;
}

// Prefer an uploaded site logo at /uploads/site-logo.webp or /uploads/site-logo.png; fall back to inline SVG
// Look for several common logo filenames and use the first one found
const logoCandidates = [
  'site-logo.webp',
  'site-logo.png',
  'Tzaneen_Logo_Blue.png',
  'Tzaneen_Tagline_Black.png',
  'church-default.webp'
];
let siteLogoExists = false;
let siteLogoWebPath = '';
try {
  for (const name of logoCandidates) {
    const abs = path.join(process.cwd(), 'public', 'uploads', name);
    if (fs.existsSync(abs)) {
      siteLogoExists = true;
      siteLogoWebPath = `${base}uploads/${name}`;
      break;
    }
  }
} catch (e) {
  siteLogoExists = false;
}
