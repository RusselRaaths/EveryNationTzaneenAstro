---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Contact Us - Every Nation Tzaneen"
  description="Get in touch with Every Nation Tzaneen. Find our location, service times, contact details, and ministry leaders."
>
  <PageHeader
    title="Contact Us"
    subtitle="We'd love to hear from you"
    backgroundImage="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1920&h=600&fit=crop&crop=center"
  />

  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Get in Touch</h2>
          <p class="text-gray-700 text-lg mb-8">
            Whether you have questions about our church, ministries, service times, or how to get connected, we'd be happy to hear from you.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-1">Address</h3>
                <p class="text-gray-700">Highschool Ben Vorster Hall</p>
                <p class="text-gray-700">1 Boundary Street</p>
                <p class="text-gray-700">Premierpark, Tzaneen</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h18M8 5V3h8v2m-9 4h10m-9 4h10m-9 4h10" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-1">Service Times</h3>
                <p class="text-gray-700">Sunday Morning Service: 9:15 AM</p>
                <p class="text-gray-700">Pre-Service Prayer: 8:15 AM - 8:45 AM</p>
                <p class="text-gray-700">Friday Morning Prayer: 05:30 AM (Google Meet)</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m0 0l4-4m-4 4l4 4" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-1">Phone & Email</h3>
                <p>
                  <a href="tel:+27727627339" class="text-primary-600 hover:underline">(+27) 72 762 7339</a>
                </p>
                <p>
                  <a href="mailto:info@entzn.org" class="text-primary-600 hover:underline">info@entzn.org</a>
                </p>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <Button href="https://www.google.com/maps/dir/?api=1&destination=-23.837301716885072,30.152549625359356" target="_blank" variant="primary">
              Get Directions
            </Button>
          </div>
        </div>

        <div class="bg-gray-100 rounded-lg overflow-hidden min-h-[500px]">
          <iframe
            class="w-full h-full min-h-[500px] border-0"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps?q=-23.837301716885072,30.152549625359356&z=17&output=embed"
            title="Every Nation Tzaneen location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section id="prayer" class="py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Prayer Request</h2>
        <p class="text-lg text-gray-600">
          We'd be honored to pray with you and for you. Share your request and our team will stand with you in faith.
        </p>
      </div>

      <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-sm p-8">
        <form
          onsubmit="(function(){ const name=document.getElementById('prayer-name')?.value||''; const email=document.getElementById('prayer-email')?.value||''; const request=document.getElementById('prayer-request')?.value||''; const body = `Prayer Request%0A%0AName: ${encodeURIComponent(name)}%0AEmail: ${encodeURIComponent(email)}%0A%0ARequest:%0A${encodeURIComponent(request)}`; window.location.href=`mailto:info@entzn.org?subject=Prayer%20Request&body=${body}`; return false; })()"
          class="space-y-6"
        >
          <div>
            <label for="prayer-name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
            <input id="prayer-name" type="text" class="w-full rounded-md border border-gray-300 px-4 py-3" placeholder="Your name" />
          </div>

          <div>
            <label for="prayer-email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input id="prayer-email" type="email" class="w-full rounded-md border border-gray-300 px-4 py-3" placeholder="you@example.com" />
          </div>

          <div>
            <label for="prayer-request" class="block text-sm font-medium text-gray-700 mb-2">Prayer Request</label>
            <textarea id="prayer-request" rows="6" class="w-full rounded-md border border-gray-300 px-4 py-3" placeholder="How can we pray for you?"></textarea>
          </div>

          <Button type="submit" variant="primary">
            Submit Prayer Request
          </Button>
        </form>
      </div>
    </div>
  </section>

  <section id="newsletter" class="py-16 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Newsletter Signup</h2>
        <p class="text-lg text-gray-600">
          Stay informed about church news, events, and ministry opportunities.
        </p>
      </div>

      <div class="max-w-2xl mx-auto bg-gray-50 rounded-lg shadow-sm p-8">
        <form
          onsubmit="(function(){ const name=document.getElementById('newsletter-name')?.value||''; const email=document.getElementById('newsletter-email')?.value||''; const body = `Newsletter Signup%0A%0AName: ${encodeURIComponent(name)}%0AEmail: ${encodeURIComponent(email)}`; window.location.href=`mailto:info@entzn.org?subject=Newsletter%20Signup&body=${body}`; return false; })()"
          class="space-y-6"
        >
          <div>
            <label for="newsletter-name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
            <input id="newsletter-name" type="text" class="w-full rounded-md border border-gray-300 px-4 py-3" placeholder="Your name" />
          </div>

          <div>
            <label for="newsletter-email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input id="newsletter-email" type="email" class="w-full rounded-md border border-gray-300 px-4 py-3" placeholder="you@example.com" />
          </div>

          <Button type="submit" variant="primary">
            Sign Up
          </Button>
        </form>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Meet Our Ministry Contacts</h2>
          <p class="text-lg text-gray-600">
            Reach out directly to the right person for pastoral care, children's ministry, youth ministry, or administration.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-lg shadow-sm p-6 flex items-start gap-4">
            <img src={`${base}/uploads/staff/Willem.webp`} alt="Willem - Pastoral Care" class="w-20 h-20 rounded-full object-cover" />
            <div>
              <h3 class="text-xl font-semibold mb-1">Willem van Zyl</h3>
              <p class="text-primary-600 mb-2">Pastoral Care</p>
              <p class="text-gray-700 mb-2">For pastoral support, spiritual guidance, and church leadership questions.</p>
              <a href="mailto:Willem.vanzyl@entzaneen.co.za" class="text-primary-600 hover:underline block">Willem.vanzyl@entzaneen.co.za</a>
              <a href="tel:+27728222527" class="text-primary-600 hover:underline block">+27 72 822 2527</a>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-6 flex items-start gap-4">
            <img src={`${base}/uploads/staff/Lollo.webp`} alt="Lorraine - Children's Ministry" class="w-20 h-20 rounded-full object-cover" />
            <div>
              <h3 class="text-xl font-semibold mb-1">Lorraine van Zyl</h3>
              <p class="text-primary-600 mb-2">Children's Ministry</p>
              <p class="text-gray-700 mb-2">For children's ministry questions, family support, and kids' programs.</p>
              <a href="mailto:Lorraine.vanzyl@entzaneen.co.za" class="text-primary-600 hover:underline block">Lorraine.vanzyl@entzaneen.co.za</a>
              <a href="tel:+27844324998" class="text-primary-600 hover:underline block">+27 84 432 4998</a>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-6 flex items-start gap-4">
            <img src={`${base}/uploads/staff/Ludwig.webp`} alt="Ludwig - Youth Ministry" class="w-20 h-20 rounded-full object-cover" />
            <div>
              <h3 class="text-xl font-semibold mb-1">Ludwig Eksteen</h3>
              <p class="text-primary-600 mb-2">Youth Ministry</p>
              <p class="text-gray-700 mb-2">For youth ministry, student discipleship, and next-generation involvement.</p>
              <a href="mailto:ludwig.eksteen@entzaneen.co.za" class="text-primary-600 hover:underline block">ludwig.eksteen@entzaneen.co.za</a>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow-sm p-6 flex items-start gap-4">
            <img src={`${base}/uploads/staff/Angie.webp`} alt="Angie - Admin" class="w-20 h-20 rounded-full object-cover" />
            <div>
              <h3 class="text-xl font-semibold mb-1">Angelique Eksteen</h3>
              <p class="text-primary-600 mb-2">Administration</p>
              <p class="text-gray-700 mb-2">For office coordination, general information, and administrative support.</p>
              <a href="mailto:info@entzn.org" class="text-primary-600 hover:underline block">info@entzn.org</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
