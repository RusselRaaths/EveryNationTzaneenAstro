---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/UI/Button.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Generate static paths for all ministries
export async function getStaticPaths() {
  try {
    const ministryEntries = await getCollection("ministries", ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true;
    });

    return ministryEntries.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
  } catch (error) {
    return [];
  }
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const logoUrl =
  entry.data.logo ||
  (entry.slug === "childrens-ministry"
    ? `${base}/uploads/Every%20Nation%20Tzaneen%20Kids.webp`
    : undefined);

const backgroundImage =
  entry.slug === "childrens-ministry"
    ? `${base}/uploads/1.webp`
    : `${base}/uploads/ministry-detail-bg.webp`;

const backgroundImages =
  entry.slug === "worship-ministry"
    ? [
        `${base}/uploads/home-1.webp`,
        `${base}/uploads/home-2.webp`,
        `${base}/uploads/home-3.webp`,
      ]
    : undefined;
---

<BaseLayout
  title={`${entry.data.title} - Ministries - Every Nation Tzaneen`}
  description={entry.data.summary}
  image={entry.data.image ? { url: entry.data.image, alt: entry.data.title } : undefined}
>
  <PageHeader
    title={entry.data.title}
    subtitle={entry.data.summary}
    backgroundImage={backgroundImage}
    backgroundImages={backgroundImages}
    imageFit={entry.slug === "childrens-ministry" ? "contain" : "cover"}
    imagePosition={entry.slug === "childrens-ministry" ? "top center" : "center"}
    tile={entry.slug === "childrens-ministry" ? 4 : 1}
    repeatX={entry.slug === "childrens-ministry"}
  />

  <section class="py-16">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        {logoUrl && (
          <div class="mb-8 flex justify-center">
            <img src={logoUrl} alt={entry.data.title} class="max-h-28 w-auto object-contain" />
          </div>
        )}

        <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-li:text-gray-700 prose-a:text-primary-600">
          <Content />
        </article>

        <div class="mt-12">
          <Button href={`${base}/ministries`} variant="outline">
            Back to All Ministries
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
