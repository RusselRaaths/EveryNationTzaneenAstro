---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Fetch all ministries
const all = await getCollection("ministries", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

// Filter out specific ministries we want to hide, then sort by order or name
const excludedSlugs = new Set(["mens-ministry", "womens-ministry", "community-outreach"]);
const ministries = all
  .filter((m) => !excludedSlugs.has(m.slug))
  .sort((a, b) => {
    const ao = a.data.order ?? 999;
    const bo = b.data.order ?? 999;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  });
---

<BaseLayout title="Our Ministries" description="Discover our ministries.">
  <PageHeader
    title="Our Ministries"
    subtitle="Discover how you can grow, connect, and serve."
    backgroundImage={`${base}/uploads/ministries-header-bg.webp`}
  />

  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Explore Our Ministries</h2>
        <p class="text-lg text-gray-600">
          Explore our ministries to grow in faith, connect with community, and serve.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {ministries.map((m) => (
          <a
            href={`${base}/ministries/${m.slug}`}
            class="block bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-gray-100"
          >
            {m.data.image && (
              <img
                src={m.data.image}
                alt={m.data.title}
                class="w-full h-48 object-cover"
              />
            )}

            <div class="p-6">
              <h3 class="text-xl font-bold mb-2">{m.data.title}</h3>
              {m.data.summary && (
                <p class="text-gray-600">{m.data.summary}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
