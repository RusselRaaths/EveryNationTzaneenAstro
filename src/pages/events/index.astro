---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import Button from "../../components/UI/Button.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/dateUtils";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Fetch all events
const allEvents = await getCollection("events", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

// Sort events by date descending
const events = allEvents.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const headerImages = [
  `${base}/uploads/events/whatsapp-2026-02-22-22-09-35.webp`,
  `${base}/uploads/events/whatsapp-2026-02-22-22-09-36.webp`,
  `${base}/uploads/events/whatsapp-2026-02-22-22-09-360.webp`,
];
---

<BaseLayout
  title="Events - Every Nation Tzaneen"
  description="Stay up to date with church events, gatherings, and special occasions at Every Nation Tzaneen."
>
  <PageHeader
    title="Events"
    subtitle="Stay connected with what's happening in our church community"
    backgroundImages={headerImages}
  />

  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Upcoming & Recent Events</h2>
        <p class="text-lg text-gray-600">
          Join us for special gatherings, ministry opportunities, and community events.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {events.map((event) => (
          <article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-gray-100">
            {event.data.image && (
              <img
                src={event.data.image}
                alt={event.data.title}
                class="w-full h-48 object-cover"
              />
            )}

            <div class="p-6">
              <p class="text-sm font-semibold text-primary-600 mb-2">
                {formatDate(event.data.date)}
              </p>

              <h3 class="text-xl font-bold mb-3">{event.data.title}</h3>

              {event.data.summary && (
                <p class="text-gray-600 mb-4">{event.data.summary}</p>
              )}

              {event.data.location && (
                <p class="text-sm text-gray-500 mb-4">{event.data.location}</p>
              )}

              <Button href={`${base}/events/${event.slug}`} variant="outline">
                Learn More
              </Button>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a
          href={`${base}/contact`}
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 rounded-lg shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          Ask About Upcoming Events
        </a>
      </div>
    </div>
  </section>
</BaseLayout>